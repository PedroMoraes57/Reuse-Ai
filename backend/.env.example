DJANGO_SECRET_KEY=django-insecure-change-me
DJANGO_DEBUG=True
FRONTEND_URL=http://127.0.0.1:5173
EMAIL_BRAND_NAME=Reuse.AI
DEFAULT_FROM_NAME=Reuse.AI
DEFAULT_FROM_EMAIL=noreply@reuse.ai
SUPPORT_EMAIL=suporte@reuse.ai
GOOGLE_OAUTH_CLIENT_ID=
# Chatbot conversacional com LLM:
# Opcao mais barata: Ollama local
# CHATBOT_LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5:7b-instruct
# OLLAMA_BASE_URL=http://localhost:11434/api
# OLLAMA_TIMEOUT_SECONDS=60
#
# Opcao opcional: OpenAI
# CHATBOT_LLM_PROVIDER=openai
# OPENAI_API_KEY=sua-chave-openai
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=30
# Para entrega real em Gmail, Hotmail, Yahoo e outros provedores, configure SMTP:
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.seu-provedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=usuario@seudominio.com
EMAIL_HOST_PASSWORD=sua-senha-ou-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=20
# Em desenvolvimento local, se quiser expor o link de verificação na resposta da API:
# DJANGO_EXPOSE_VERIFICATION_LINK=True
